{
  "name": "supergit",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "start": "bun run build:bun && bun run start.ts",
    "dev": "bun run dev.ts",
    "stop-dev": "bun run stop-dev.ts",
    "test": "bun test packages/",
    "test:watch": "bun test --watch packages/",
    "test:coverage": "bun test --coverage packages/",
    "build": "bun run build:native && electrobun build --env=stable && bun run scripts/build-summary.ts",
    "build:native": "bun run scripts/build-native.ts",
    "build:bun": "cd packages/ui && bun run build",
    "icons": "node scripts/generate-icons.mjs"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "electrobun": "^1.18.1",
    "sharp": "^0.34.5",
    "typescript": "^5"
  },
  "engines": {
    "bun": ">=1.3.14"
  },
  "packageManager": "bun@1.3.14"
}
