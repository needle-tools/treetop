{
  "name": "supergit",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "start": "bun run build:bun && bun run start.ts",
    "dev": "bun run dev.ts",
    "dev:temp": "bash -lc 'TREETOP_TEMP_WORKSPACE_FROM=\"$HOME/supergit/workspaces/default\" SUPERGIT_DEV_PORT=17777 SUPERGIT_DEV_UI_PORT=17779 bun dev'",
    "dev:site": "cd packages/site && bun run dev",
    "build:site": "cd packages/site && bun run build",
    "stop-dev": "bun run stop-dev.ts",
    "test": "bash -lc 'bun test $(find packages -type f \\( -path \"*/test/*.test.ts\" -o -path \"*/test/*.spec.ts\" -o -path \"*/test/*.test.js\" -o -path \"*/test/*.spec.js\" \\))'",
    "test:watch": "bash -lc 'bun test --watch $(find packages -type f \\( -path \"*/test/*.test.ts\" -o -path \"*/test/*.spec.ts\" -o -path \"*/test/*.test.js\" -o -path \"*/test/*.spec.js\" \\))'",
    "test:coverage": "bash -lc 'bun test --coverage $(find packages -type f \\( -path \"*/test/*.test.ts\" -o -path \"*/test/*.spec.ts\" -o -path \"*/test/*.test.js\" -o -path \"*/test/*.spec.js\" \\))'",
    "test:two-daemon": "SUPERGIT_TWO_DAEMON_TESTS=1 bun test ./packages/daemon/test/two-daemon-e2e.test.ts",
    "test:provision-docker": "SUPERGIT_DOCKER_TESTS=1 bun test ./packages/daemon/test/provision-docker-e2e.test.ts",
    "format": "prettier --write \"packages/**/*.{js,ts,svelte,css,json}\" \"*.ts\"",
    "format:check": "prettier --check \"packages/**/*.{js,ts,svelte,css,json}\" \"*.ts\"",
    "build": "bun run scripts/patch-launcher.ts && bun run build:native && electrobun build --env=stable && bun run scripts/build-summary.ts",
    "build:launch": "bun run scripts/build-launch.ts",
    "build:native": "bun run scripts/build-native.ts",
    "build:bun": "cd packages/ui && bun run build",
    "icons": "node scripts/generate-icons.mjs",
    "notify:test": "bun run scripts/notify-discord.ts --title \"Webhook test\" --status info --details \"Test notification from supergit\" --context \"local test\""
  },
  "devDependencies": {
    "@types/bun": "latest",
    "electrobun": "1.18.4-beta.3",
    "prettier": "^3.8.3",
    "prettier-plugin-svelte": "^4.0.1",
    "sharp": "^0.34.5",
    "typescript": "^5"
  },
  "engines": {
    "bun": ">=1.3.14"
  },
  "packageManager": "bun@1.3.14"
}
