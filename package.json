{
  "name": "supergit",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run dev.ts",
    "stop-dev": "bun run stop-dev.ts",
    "test": "bun test packages/",
    "test:watch": "bun test --watch packages/",
    "test:coverage": "bun test --coverage packages/",
    "build": "cd packages/ui && bun run build",
    "start": "bun run build && bun run start.ts"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5"
  }
}
